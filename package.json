{
  "name": "claude-theseus",
  "version": "0.2.1",
  "description": "Wizard TUI that rebuilds a Claude Code environment (marketplaces, plugins, MCP servers, project .claude/ scaffold) from a known-good setup.",
  "type": "module",
  "bin": {
    "claude-theseus": "bin/cli.js"
  },
  "files": [
    "bin",
    "src",
    "assets"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node bin/cli.js",
    "plan": "node bin/cli.js --print-plan",
    "test": "node test/smoke.js && node test/snake.test.js"
  },
  "dependencies": {
    "cross-spawn": "^7.0.6",
    "htm": "^3.1.1",
    "ink": "^5.0.1",
    "ink-gradient": "^3.0.0",
    "ink-spinner": "^5.0.0",
    "react": "^18.3.1"
  }
}
